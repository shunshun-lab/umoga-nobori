# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mmd_event_db?schema=public"

# Google Places (場所の自動入力・イベント作成/編集)
# GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ---- Google OAuth（2系統：ログイン用とMeet用は別クライアント） ----
# ログイン用（NextAuth）。リダイレクトURI に …/api/auth/callback/google を登録すること。
GOOGLE_CLIENT_ID=your_google_client_id_for_signin
GOOGLE_CLIENT_SECRET=your_google_client_secret_for_signin

# Google Meet 専用（Calendar API でMeetリンク発行）。ログイン用とは別のOAuthクライアントを推奨。
# 本番では Meet 用クライアント（例: 114313188710-...）をここに設定する。
GOOGLE_MEET_CLIENT_ID=your_google_meet_client_id
GOOGLE_MEET_CLIENT_SECRET=your_google_meet_client_secret
GOOGLE_MEET_REFRESH_TOKEN=your_google_meet_refresh_token

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# LINE Login
LINE_CHANNEL_ID=your_line_channel_id
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CALLBACK_URL=http://localhost:3000/api/auth/callback/line

# Kyoso Cloud Agent
KYOSO_BASE_URL=http://localhost:3000
KYOSO_API_KEY=your_kyoso_api_key
# AUTH_MODE=TEST のときに使うテスト用 JWT
KYOSO_TEST_JWT=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudinary (画像アップロード + AIサムネイルの永続化。未設定だとAI画像URLは期限切れで表示されなくなる)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Firebase Client (Required for Phone Auth UI)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# Firebase Admin (Required for Phone Auth)
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", ...}'

# Stripe (クラウドファンディング決済)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Shopify (Community Commerce連携。shopify_centralizedモードのコミュニティで必要)
# 新規: 設定 > アプリ > Develop apps > Build apps in Dev Dashboard でアプリ作成・インストール
# access token は管理画面でコピーしない。Client Credentials Grant でプログラム的に取得
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=shpss_xxxxxxxx
# レガシー（2026年1月より前に admin で作成済みのカスタムアプリのみ）:
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxx
# Webhook: GraphQL API で登録する場合、HMAC 検証に SHOPIFY_CLIENT_SECRET を使用（追加設定不要）
# 管理画面で Webhook を作成した場合のみ:
# SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# NFT Provider (現在は mock のみ)
# NFT_PROVIDER=mock

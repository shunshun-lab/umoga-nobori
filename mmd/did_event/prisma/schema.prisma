// -------- JXC 参加導線 --------

enum JxcContactStatus {
  new
  auto_classified
  review_needed
  contacted
  active
  archived
  opted_out
}

enum JxcSubmissionType {
  event_notice
  referral
  co_creation
}

enum JxcSubmissionStatus {
  submitted
  reviewed
  followup_needed
  followup_done
  closed
}

model JxcContact {
  id            String           @id @default(cuid())
  userId        String?          @unique
  name          String
  email         String          @unique
  lineUserId    String?
  sourceChannel String?
  sourceArticle String?
  lineConnected Boolean          @default(false)
  status        JxcContactStatus  @default(new)
  priority      Int?
  score         Int?
  optOut        Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  user          User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  submissions   JxcSubmission[]

  @@index([email])
  @@index([status])
  @@index([lineUserId])
  @@map("jxc_contacts")
}

model JxcSubmission {
  id               String                @id @default(cuid())
  contactId        String
  userId           String?
  type             JxcSubmissionType
  payloadJson      String
  consentUpdates   Boolean?              @default(false)
  consentContact   Boolean?              @default(true)
  submissionStatus JxcSubmissionStatus   @default(submitted)
  submittedAt      DateTime              @default(now())
  contact          JxcContact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  referral         JxcReferral?
  collabProfile    JxcCollabProfile?

  @@index([contactId])
  @@index([type])
  @@index([submissionStatus])
  @@map("jxc_submissions")
}

model JxcReferral {
  id              String        @id @default(cuid())
  submissionId    String        @unique
  targetType      String
  targetName      String
  reason          String
  url             String?
  relationship    String?
  followupAllowed Boolean?      @default(true)
  submission      JxcSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("jxc_referrals")
}

model JxcCollabProfile {
  id              String        @id @default(cuid())
  submissionId    String        @unique
  interestedAreas String?
  skills          String?
  experience      String?
  availability    String?
  contactAllowed  Boolean       @default(true)
  submission      JxcSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("jxc_collab_profiles")
}

model JxcArticle {
  id          String   @id @default(cuid())
  title       String
  summary     String?
  externalUrl String
  publishedAt DateTime
  thumbnail   String?
  tags        String?
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt])
  @@map("jxc_articles")
}

model ApiKey {
  id          String    @id @default(cuid())
  key         String    @unique
  clientName  String
  communityId String?
  scopes      String[]  @default([])
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  community   Community? @relation(fields: [communityId], references: [id])

  @@index([key])
  @@map("api_keys")
}

// -------- Usage & Invoice --------

model UsageRecord {
  id          String   @id @default(cuid())
  communityId String
  period      String   // "2026-03" (月次)
  metricType  String   // "active_members", "events_held", "points_issued", "checkins", "orders"
  value       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, period, metricType])
  @@index([communityId, period])
  @@map("usage_records")
}

model Invoice {
  id              String    @id @default(cuid())
  communityId     String
  period          String    // "2026-03"
  status          String    @default("DRAFT") // DRAFT | ISSUED | PAID | VOID
  totalAmount     Int       @default(0)
  currency        String    @default("jpy")
  items           Json      @default("[]") // [{description, quantity, unitPrice, amount}]
  stripeInvoiceId String?   @unique
  issuedAt        DateTime?
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, period])
  @@index([communityId, status])
  @@map("invoices")
}

// -------- Online Session --------

model OnlineSession {
  id        String    @id @default(cuid())
  userId    String
  eventId   String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
  duration  Int?      // seconds (computed on leave or by cron)
  source    String    @default("web") // "web", "google_meet", "youtube", "custom"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, userId])
  @@index([eventId, joinedAt])
  @@map("online_sessions")
}


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                   @id @default(cuid())
  name                   String?
  email                  String?                  @unique
  lineUserId             String?                  @unique
  did                    String?                  @unique
  firebaseUid            String?                  @unique
  image                  String?
  provider               String                   @default("line")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  emailVerified          DateTime?
  isAdmin                Boolean                  @default(false)
  password               String?
  website                String?
  bio                    String?
  exchangeScope          String                   @default("COMMUNITY")
  googleEmail            String?
  googleId               String?                  @unique
  instagramUrl           String?
  isVerified             Boolean                  @default(false)
  linkedinUrl            String?
  location               String?
  phoneNumber            String?
  points                 Int                      @default(0)
  preferences            String?
  profileConfig          String?
  realName               String?
  socialLinks            String?
  twitterUrl             String?
  whatsappUserId         String?                  @unique
  personalCommunityId    String?                  @unique
  displayName            String?
  phoneNumberHash        String?
  tutorialStatus         TutorialStatus           @default(PENDING)
  stripeCustomerId       String?                  @unique
  notificationSettings   Json?
  interests              String[]         @default([])
  referralCode           String?                  @unique
  profileReferralTiers   Json?                    // [{ n: 1, label: "特典", emoji: "🎁" }, ...]
  accounts               Account[]
  campaignCommentReplies CampaignCommentReply[]
  campaignComments       CampaignComment[]
  campaignSupporters     CampaignSupporter[]
  campaignUpdates        CampaignUpdate[]
  comments               Comment[]
  communities            Community[]              @relation("OrganizerCommunities")
  communityMembers       CommunityMember[]
  receivedConnections    Connection[]             @relation("MyReceivedConnections")
  sentConnections        Connection[]             @relation("MySentConnections")
  contestEntries         ContestEntry[]
  contestVotes           ContestVote[]
  contests               Contest[]                @relation("OrganizerContests")
  didIssuanceRequests    DidIssuanceRequest[]
  Entitlement            Entitlement[]
  credentials            EventCredential[]
  events                 Event[]                  @relation("OwnerEvents")
  favoritedBy            Favorite[]               @relation("FavoritedUsers")
  favorites              Favorite[]
  following              Follow[]                 @relation("following")
  followedBy             Follow[]                 @relation("followedBy")
  issuedInviteCodes      InviteCode[]
  MemberFact             MemberFact[]
  messages               Message[]
  notifications          Notification[]
  orders                 Order[]
  participants           Participant[]
  payments               Payment[]
  pledges                Pledge[]
  pointTransactions      PointTransaction[]
  posts                  Post[]
  projects               Project[]
  questApplications      QuestApplication[]
  quests                 Quest[]
  recurringTemplates     RecurringEventTemplate[]
  RoleGrant              RoleGrant[]
  sessions               Session[]
  shippingAddresses      ShippingAddress[]
  phoneVerification      UserPhoneVerification?
  pushSubscriptions      PushSubscription[]
  authenticators         Authenticator[]
  chatConversations      ChatConversation[]
  personalCommunity      Community?               @relation("UserPersonalCommunity", fields: [personalCommunityId], references: [id])
  coOrganizedEvents      Event[]                  @relation("EventCoOrganizers")
  eventReviews           EventReview[]
  profileDrafts          ProfileDraft[]
  claimedQuests          QuestApplication[]       @relation("ClaimedQuests")
  claimedOrders          Order[]                  @relation("ClaimedOrders")
  claimedParticipants    Participant[]            @relation("ClaimedParticipants")

  @@index([phoneNumberHash])
  @@map("users")
}

model UserPhoneVerification {
  id         String   @id @default(cuid())
  userId     String   @unique
  phoneHash  String   @unique
  verifiedAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_phone_verifications")
}

model DidIssuanceRequest {
  id           String   @id @default(cuid())
  userId       String
  status       String   @default("PENDING")
  didRef       String?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("did_issuance_requests")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  message     String
  link        String?
  isRead      Boolean  @default(false)
  eventId     String?
  communityId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followedBy", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@map("follows")
}

model Connection {
  id          String   @id @default(cuid())
  requesterId String
  recipientId String
  status      String   @default("PENDING")
  message     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  recipient   User     @relation("MyReceivedConnections", fields: [recipientId], references: [id], onDelete: Cascade)
  requester   User     @relation("MySentConnections", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@map("connections")
}

model PointTransaction {
  id              String    @id @default(cuid())
  userId          String
  amount          Int
  description     String
  createdAt       DateTime  @default(now())
  communityId     String
  createdByUserId String?
  type            String    @default("EARN")
  community       Community @relation(fields: [communityId], references: [id], onDelete: SetNull)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_transactions")
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  imageUrl    String?
  points      Int
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("items")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Event {
  id                     String                  @id @default(cuid())
  title                  String
  description            String?
  imageUrl               String?
  startAt                DateTime
  endAt                  DateTime?
  location               String?
  capacity               Int?
  ownerId                String?
  isPublic               Boolean                 @default(true)
  status                 String                  @default("draft")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  format                 String                  @default("offline")
  onlineUrl              String?
  instanceNumber         Int?
  isApproved             Boolean                 @default(false)
  isRecurring            Boolean                 @default(false)
  recurringTemplateId    String?
  category               String?
  tags                   String?
  website                String?
  acceptedPaymentMethods String?
  bankDetails            String?
  communityId            String?
  concept                String?
  googleMapsUrl          String?
  keyword                String?
  needs                  String?
  organizerCommunityId   String?
  projectId              String?
  rtmpKey                String?
  target                 String?
  theme                  String?
  venueAddress           String?
  venueLat               Float?
  venueLng               Float?
  venueTitle             String?
  youtubeBroadcastId     String?
  youtubeStreamUrl       String?
  paymentDeadline        DateTime?
  registrationDeadline   DateTime?
  approvalRequired       Boolean                 @default(false)
  createdByUserId        String?
  communities            Community[]
  contests               Contest[]
  credentials            EventCredential[]
  tickets                EventTicket[]
  questions              RegistrationQuestion[]
  blasts                 Blast[]
  community              Community?              @relation("AttachedCommunity", fields: [communityId], references: [id])
  organizerCommunity     Community?              @relation("CommunityEvents", fields: [organizerCommunityId], references: [id])
  owner                  User?                   @relation("OwnerEvents", fields: [ownerId], references: [id])
  project                Project?                @relation(fields: [projectId], references: [id])
  recurringTemplate      RecurringEventTemplate? @relation(fields: [recurringTemplateId], references: [id])
  favorites              Favorite[]
  participants           Participant[]
  allowedRoles           CommunityRole[]         @relation("EventAllowedRoles")
  coOrganizerCommunities Community[]             @relation("EventCoOrganizerCommunities")
  coOrganizers           User[]                  @relation("EventCoOrganizers")
  reviews                EventReview[]

  @@map("events")
}

model Blast {
  id        String   @id @default(cuid())
  eventId   String
  title     String
  content   String
  type      String   @default("INFO") // INFO, URGENT, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, createdAt])
  @@map("blasts")
}

model RegistrationQuestion {
  id          String   @id @default(cuid())
  eventId     String
  type        String   @default("TEXT") // TEXT, PARAGRAPH, SELECT, RADIO, CHECKBOX
  label       String
  description String?  // 説明（Google Form の「説明テキスト」）
  options     String[] @default([]) // For SELECT/RADIO/CHECKBOX
  required    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  answers     RegistrationAnswer[]

  @@index([eventId, order])
  @@map("registration_questions")
}

model RegistrationAnswer {
  id            String               @id @default(cuid())
  questionId    String
  participantId String
  value         String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  question      RegistrationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  participant   Participant          @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([participantId])
  @@map("registration_answers")
}

model EventTicket {
  id           String        @id @default(cuid())
  eventId      String
  name         String
  description  String?
  price        Int           @default(0)
  limit        Int?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  event        Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participants Participant[]

  @@map("event_tickets")
}

model Project {
  id              String       @id @default(cuid())
  communityId     String?
  ownerId         String
  title           String
  issue           String?
  value           String?
  businessPlan    String?
  roadmap         String?
  status          String       @default("active")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  domainModel     Json?
  createdByUserId String?
  resources       String?
  solution        String?
  target          String?
  url             String?
  campaigns       Campaign[]
  decisions       Decision[]
  events          Event[]
  intakes         IntakeItem[]
  posts           Post[]
  community       Community?   @relation(fields: [communityId], references: [id])
  owner           User         @relation(fields: [ownerId], references: [id])
  tickets         Ticket[]

  @@map("projects")
}

model Favorite {
  id           String     @id @default(cuid())
  userId       String
  eventId      String?
  questId      String?
  createdAt    DateTime   @default(now())
  communityId  String?
  targetUserId String?
  campaignId   String?
  postId       String?
  campaign     Campaign?  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  community    Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  event        Event?     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  quest        Quest?     @relation(fields: [questId], references: [id], onDelete: Cascade)
  post         Post?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  targetUser   User?      @relation("FavoritedUsers", fields: [targetUserId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@unique([userId, questId])
  @@unique([userId, communityId])
  @@unique([userId, targetUserId])
  @@unique([userId, campaignId])
  @@unique([userId, postId])
  @@map("favorites")
}

model Participant {
  id                    String       @id @default(cuid())
  userId                String
  eventId               String
  status                String       @default("joined")
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  paymentMethod         String?
  paymentStatus         String       @default("free")
  reminded1h            Boolean      @default(false)
  reminded24h           Boolean      @default(false)
  stripePaymentIntentId String?
  ticketId              String?
  event                 Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticket                EventTicket? @relation(fields: [ticketId], references: [id])
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers               RegistrationAnswer[]
  claimedById           String?
  claimedAt             DateTime?
  claimedBy             User?        @relation("ClaimedParticipants", fields: [claimedById], references: [id])

  @@unique([userId, eventId])
  @@map("participants")
}

model EventCredential {
  id         String   @id @default(cuid())
  userId     String
  eventId    String
  vcRecordId String
  vcJobId    String?
  status     String   @default("ISSUED")
  jwt        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@map("event_credentials")
}

model RecurringEventTemplate {
  id              String    @id @default(cuid())
  title           String
  description     String?
  imageUrl        String?
  dayOfWeek       Int?
  startTime       String
  endTime         String?
  location        String?
  format          String    @default("online")
  capacity        Int?
  ownerId         String
  isActive        Boolean   @default(true)
  maxFutureEvents Int       @default(2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  customDays      String?
  endDate         DateTime?
  endType         String    @default("never")
  interval        Int       @default(1)
  maxOccurrences  Int?
  onlineUrl       String?
  repeatType      String    @default("weekly")
  weekOfMonth     Int?
  communityId     String?
  projectId       String?
  events          Event[]
  owner           User      @relation(fields: [ownerId], references: [id])

  @@map("recurring_event_templates")
}

model Community {
  id                 String             @id @default(cuid())
  name               String
  description        String?
  slug               String             @unique
  imageUrl           String?
  bannerUrl          String?
  hpUrl              String?
  twitterUrl         String?
  instagramUrl       String?
  discordUrl         String?
  lineUrl            String?
  lineOpenChatUrl    String?
  scope              String             @default("OFFICIAL")
  isOfficial         Boolean            @default(false)
  isPublic           Boolean            @default(true)
  constitution       String?
  location           String?
  lat                Float?
  lng                Float?
  establishedAt      DateTime?
  isDashboardEnabled Boolean            @default(true)
  customHtml         String?
  pageConfig         String?
  aiPrompt           String?
  aiTheme            String?            @default("default")
  theme              String?
  ownerOrganizerId   String?
  eventId            String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  createdByUserId    String?
  ownerUserId        String?
  type               CommunityType      @default(NORMAL)
  inviteRewardPoints Int                @default(0)
  channels           Channel[]
  event              Event?             @relation(fields: [eventId], references: [id])
  owner              User?              @relation("OrganizerCommunities", fields: [ownerOrganizerId], references: [id])
  members            CommunityMember[]
  roles              CommunityRole[]
  Entitlement        Entitlement[]
  attachedEvents     Event[]            @relation("AttachedCommunity")
  organizedEvents    Event[]            @relation("CommunityEvents")
  favorites          Favorite[]
  inviteCodes        InviteCode[]
  MemberFact         MemberFact[]
  pointTransactions  PointTransaction[]
  posts              Post[]
  projects           Project[]
  quests             Quest[]
  RoleGrant          RoleGrant[]
  RolePolicy         RolePolicy[]
  personalUser       User?              @relation("UserPersonalCommunity")
  coOrganizedEvents  Event[]            @relation("EventCoOrganizerCommunities")
  resources          CommunityResource[]
  page               Page?
  referralTiers      Json?              // [{ n: 1, label: "特典A", emoji: "🎁" }, ...]
}


model CommunityResource {
  id          String   @id @default(cuid())
  communityId String
  name        String
  description String?
  type        String   @default("SPACE")
  capacity    Int?
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  bookings    ResourceBooking[]

  @@map("community_resources")
}

model ResourceBooking {
  id          String   @id @default(cuid())
  resourceId  String
  userId      String
  startAt     DateTime
  endAt       DateTime
  title       String?
  description String?
  status      String   @default("CONFIRMED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resource    CommunityResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, startAt, endAt])
  @@map("resource_bookings")
}

model CommunityMember {
  id           String         @id @default(cuid())
  communityId  String
  userId       String
  role         String         @default("MEMBER")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  roleId       String?
  points       Int            @default(0)
  inviteCodeId String?
  community    Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  inviteCode   InviteCode?    @relation(fields: [inviteCodeId], references: [id])
  customRole   CommunityRole? @relation(fields: [roleId], references: [id])
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
  @@map("community_members")
}

model InviteCode {
  id          String            @id @default(cuid())
  code        String            @unique
  communityId String
  issuerId    String
  usedCount   Int               @default(0)
  maxUses     Int?
  expiresAt   DateTime?
  createdAt   DateTime          @default(now())
  members     CommunityMember[]
  community   Community         @relation(fields: [communityId], references: [id], onDelete: Cascade)
  issuer      User              @relation(fields: [issuerId], references: [id], onDelete: Cascade)

  @@map("invite_codes")
}

model CommunityRole {
  id            String            @id @default(cuid())
  communityId   String
  name          String
  color         String            @default("#000000")
  permissions   String[]
  isSystem      Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  description   String?
  isPlatform    Boolean           @default(false)
  slug          String?
  members       CommunityMember[]
  community     Community         @relation(fields: [communityId], references: [id], onDelete: Cascade)
  grants        RoleGrant[]
  policies      RolePolicy[]
  allowedEvents Event[]           @relation("EventAllowedRoles")

  @@unique([communityId, slug])
  @@index([communityId, isPlatform])
  @@map("community_roles")
}

model Post {
  id          String     @id @default(cuid())
  communityId String?
  projectId   String?
  userId      String
  content     String
  imageUrl    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  campaignId  String?
  comments    Comment[]
  favorites   Favorite[]
  campaign    Campaign?  @relation("CampaignUpdates", fields: [campaignId], references: [id])
  community   Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([communityId, createdAt])
  @@map("posts")
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Contest {
  id               String         @id @default(cuid())
  title            String
  description      String?
  imageUrl         String?
  scope            String         @default("OFFICIAL")
  isOfficial       Boolean        @default(false)
  ownerOrganizerId String?
  eventId          String?
  startAt          DateTime
  endAt            DateTime
  status           String         @default("DRAFT")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  entries          ContestEntry[]
  event            Event?         @relation(fields: [eventId], references: [id])
  owner            User?          @relation("OrganizerContests", fields: [ownerOrganizerId], references: [id])

  @@map("contests")
}

model ContestEntry {
  id        String        @id @default(cuid())
  contestId String
  userId    String
  title     String?
  content   String
  imageUrl  String?
  status    String        @default("PUBLISHED")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  contest   Contest       @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes     ContestVote[]

  @@map("contest_entries")
}

model ContestVote {
  id        String       @id @default(cuid())
  entryId   String
  userId    String
  createdAt DateTime     @default(now())
  entry     ContestEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([entryId, userId])
  @@map("contest_votes")
}

model Quest {
  id              String             @id @default(cuid())
  title           String
  description     String?
  imageUrl        String?
  deadline        DateTime?
  requesterId     String?
  resourceType    String             @default("individual")
  status          String             @default("open")
  userId          String?
  communityId     String
  membersOnly     Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  createdByUserId String?
  applications    QuestApplication[]
  favorites       Favorite[]
  community       Community          @relation(fields: [communityId], references: [id])
  user            User?              @relation(fields: [userId], references: [id])

  @@map("quests")
}

model QuestApplication {
  id        String         @id @default(cuid())
  questId   String
  userId    String
  status    String         @default("PENDING")
  message   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  quest     Quest          @relation(fields: [questId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  QuestMessage[]
  claimedById String?
  claimedAt   DateTime?
  claimedBy   User?        @relation("ClaimedQuests", fields: [claimedById], references: [id])

  @@unique([questId, userId])
  @@map("quest_applications")
}

model Channel {
  id          String             @id @default(cuid())
  name        String
  type        String             @default("text")
  description String?
  communityId String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  sortOrder   Int                @default(0)
  writePolicy ChannelWritePolicy @default(ANYONE)
  community   Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@map("channels")
}

model ChannelStar {
  userId    String
  channelId String
  createdAt DateTime @default(now())

  @@id([userId, channelId])
  @@map("channel_stars")
}

model ChannelRead {
  userId            String
  channelId         String
  lastReadMessageId String?
  updatedAt         DateTime @updatedAt

  @@id([userId, channelId])

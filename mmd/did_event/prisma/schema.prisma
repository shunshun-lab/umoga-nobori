// Rate Limiting for AI features
model DailyActionLimit {
  id        String   @id @default(cuid())
  userId    String
  action    String   // e.g., "ai_thumbnail"
  date      DateTime @db.Date
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, action, date])
  @@map("daily_action_limits")
}

model EventReview {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_reviews")
}


model ProfileDraft {
  id              String    @id @default(cuid())
  userId          String?   // Nullable for anonymous drafts
  state           String    @default("DRAFT") // DRAFT, COMPLETED
  sourceArtifacts Json?     // Array of { type, url, manualText }
  inference       Json?     // Inferred data with confidence
  finalFields     Json?     // User edited fields
  privacy         String?   // PUBLIC, PRIVATE, etc.
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("profile_drafts")
}

// Community Homepage System
model Page {
  id                  String     @id @default(cuid())
  communityId         String     @unique
  slug                String     @default("home")
  publishedRevisionId String?    @unique
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  community         Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  publishedRevision Revision?  @relation("PublishedRevision", fields: [publishedRevisionId], references: [id])
  revisions         Revision[] @relation("PageRevisions")

  @@index([communityId, slug])
  @@map("pages")
}

model Revision {
  id            String   @id @default(cuid())
  pageId        String
  schemaVersion Int      @default(1)
  content       Json // The UI Tree
  status        String // DRAFT, PUBLISHED, ARCHIVED
  createdAt     DateTime @default(now())

  page          Page  @relation("PageRevisions", fields: [pageId], references: [id], onDelete: Cascade)
  publishedPage Page? @relation("PublishedRevision")

  @@map("revisions")
}


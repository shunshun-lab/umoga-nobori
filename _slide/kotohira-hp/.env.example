# Stripe (required for /api/checkout)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_TEAM=price_...

# Canva Connect API (optional, for direct Canva upload)
CANVA_CLIENT_ID=your_canva_client_id
CANVA_CLIENT_SECRET=your_canva_client_secret
# 未設定時は getAppUrl() で自動（Vercel では VERCEL_URL を使用）
# ローカル: CANVA_REDIRECT_URI=http://localhost:3000/api/canva/callback
# Vercel: 設定不要（本番URLが自動で使われます）

# Vercel デプロイ時: 未設定でも VERCEL_URL から自動で本番URLを使用
# カスタムドメインを使う場合: NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=https://kotohira-hp.vercel.app
